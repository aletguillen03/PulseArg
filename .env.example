# ─────────────────────────────────────────────────────────────────────
# PulseArg — Variables de entorno
# Copiar como .env y ajustar según el entorno.
# El archivo .env nunca debe commitearse (está en .gitignore).
# ─────────────────────────────────────────────────────────────────────

# ── Modo offline ──────────────────────────────────────────────────────
# "true" → nunca hace requests HTTP; sirve todo desde caché local.
# Útil para demos, tests y cuando no hay conexión.
OFFLINE_MODE=false

# ── TTL de caché (segundos) ───────────────────────────────────────────
# Cuánto tiempo se considera válido el caché antes de refrescar.
CACHE_TTL_DOLAR=300       # 5 min  — cotizaciones cambian rápido
CACHE_TTL_BCRA=3600       # 1 hora — datos del BCRA se publican una vez al día
CACHE_TTL_NEWS=1800       # 30 min — noticias de medios
CACHE_TTL_MARKETS=300     # 5 min  — precios de mercado
CACHE_TTL_HISTORY=3600    # 1 hora — series históricas

# ── SSL ───────────────────────────────────────────────────────────────
# El certificado de api.bcra.gob.ar es inestable (cert inválido frecuente).
# Dejar en "false" para entornos de desarrollo/local.
# Cambiar a "true" solo si el certificado es válido en tu entorno.
BCRA_VERIFY_SSL=false

# ── URLs de APIs (opcional — sobreescribir solo para tests o proxies) ─
# BLUELYTICS_URL=https://api.bluelytics.com.ar/v2/latest
# DOLARAPI_URL=https://dolarapi.com/v1/dolares
# BCRA_URL_V4=https://api.bcra.gob.ar/estadisticas/v4.0/monetarias
# BCRA_URL_V2=https://api.bcra.gob.ar/estadisticas/v2.0/datosvariable
